# ─── Frontend (Next.js) ─────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your values. Never commit .env.local.

# ── Backend API ─────────────────────────────────────────────────────────────
# Full URL to the FastAPI backend (no trailing slash).
# For Railway deployments this looks like:
#   https://<service>-production.up.railway.app
# This is set as an Environment Variable in Vercel (NOT in .env.local on prod).
# It is baked into the Next.js proxy rewrite at build time — update it in
# Vercel → Project → Settings → Environment Variables, then redeploy.
NEXT_PUBLIC_API_URL=https://bucks-backend-production.up.railway.app

# ── IPFS Gateway ────────────────────────────────────────────────────────────
# Base URL of your IPFS gateway (no trailing slash).
# Leave unset to fall back to https://ipfs.io on production and localhost:8080 in dev.
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.bucks.global

# ── Supabase ─────────────────────────────────────────────────────────────────
# Your Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://rianaojvckrbboeneots.supabase.co

# Supabase anon/public key (Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── App ─────────────────────────────────────────────────────────────────────
# Canonical public URL of the frontend (used for Open Graph metadata)
NEXT_PUBLIC_APP_URL=https://bucks.global
